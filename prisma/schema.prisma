generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Lead {
  id                Int      @id @default(autoincrement())
  nombre            String   @db.VarChar(120)
  empresa           String?  @db.VarChar(120)
  email             String   @db.VarChar(255)
  telefono          String?  @db.VarChar(30)
  tipo_proyecto     String   @db.VarChar(80)
  presupuesto_rango String?  @db.VarChar(60)
  urgencia          String?  @db.VarChar(40)
  mensaje           String?  @db.Text
  estado            String   @default("nuevo") @db.VarChar(20) // nuevo, en_progreso, completado, cancelado
  progreso          Int      @default(0)
  url_proyecto      String?  @db.VarChar(255)
  notas_internas    String?  @db.Text
  fecha_creacion    DateTime @default(now())
  fecha_actualizacion DateTime @updatedAt

  // Deal Intelligence fields
  leadScore       Int?     // 1-100 Deal Intelligence score
  leadCategory    String?  @db.VarChar(20) // prioritaria, viable, baja
  scoreFactors    String?  @db.Text // JSON string of scoring factors
  pipelineStage   String   @default("nuevo_lead") @db.VarChar(30) // nuevo_lead, lead_analizado, lead_calificado, propuesta_enviada, negociacion_activa, contrato_cerrado, contrato_perdido
  followupDay     Int?     // current followup day (1, 3, 7, 14, 21)
  followupSentAt  DateTime? // when last followup was sent

  @@map("leads")
}

model AdminUser {
  id       Int     @id @default(autoincrement())
  email    String  @unique
  password String
}

model PasswordReset {
  id        Int      @id @default(autoincrement())
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Ad {
  id          Int       @id @default(autoincrement())
  scratch     String    @db.Text                      // La idea base ingresada por Diego (o generada auto)
  headline    String?   @db.VarChar(255)              // Titular persuasivo generado por Claude
  copy        String?   @db.Text                      // Copy principal del post
  mediaUrl    String?   @db.Text                      // URL de la imagen/video (Text para URLs largas de IA)
  mediaType   String    @default("image") @db.VarChar(20) // image, video
  status      String    @default("draft") @db.VarChar(20) // draft, scheduled, published, rejected
  publishAt   DateTime?                               // Fecha/Hora programada para publicar
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("ads")
}

model ContentPost {
  id           Int            @id @default(autoincrement())
  format       String         @db.VarChar(20) // reel, carousel, story
  topic        String         @db.Text
  hook         String?        @db.Text
  body         String?        @db.Text
  cta          String?        @db.Text
  script       String?        @db.Text
  caption      String?        @db.Text
  hashtags     String?        @db.Text
  objective    String?        @db.VarChar(80)
  status       String         @default("idea") @db.VarChar(20) // idea, generated, scheduled, published
  publishAt    DateTime?
  sequence     Int?
  metrics      ContentMetrics?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@map("content_posts")
}

model ContentMetrics {
  id              Int         @id @default(autoincrement())
  postId          Int         @unique
  post            ContentPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  views           Int         @default(0)
  retention       Float       @default(0)
  saves           Int         @default(0)
  shares          Int         @default(0)
  followersGained Int         @default(0)
  comments        Int         @default(0)
  likes           Int         @default(0)
  diagnosis       String?     @db.Text
  recordedAt      DateTime    @default(now())

  @@map("content_metrics")
}

model GrowthConfig {
  id             Int      @id @default(autoincrement())
  followerCount  Int      @default(0)
  mode           String   @default("MASSIVE_REACH_STARTER") @db.VarChar(50)
  niche          String   @default("desarrollo web y software") @db.VarChar(100)
  targetAudience String   @default("empresas y emprendedores en Costa Rica") @db.Text
  activeChannel  String   @default("instagram") @db.VarChar(20)
  updatedAt      DateTime @updatedAt

  @@map("growth_config")
}

model Propuesta {
  id            Int       @id @default(autoincrement())
  token         String?   @unique @default(cuid())
  leadId        Int?
  clientName    String    @db.VarChar(120)
  clientCompany String?   @db.VarChar(120)
  clientPhone   String?   @db.VarChar(30)
  clientEmail   String?   @db.VarChar(255)
  service       String    @db.VarChar(80)
  total         Int
  proposalText  String    @db.Text
  estado        String    @default("enviada") @db.VarChar(30)
  sentVia       String?   @db.VarChar(20)
  notas         String?   @db.Text
  followupAt    DateTime?
  viewedAt      DateTime?
  sentAt        DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("propuestas")
}

model Invoice {
  id             Int       @id @default(autoincrement())
  numero         String    @db.VarChar(50)
  lead_id        Int?
  client_name    String    @db.VarChar(120)
  client_email   String?   @db.VarChar(255)
  client_company String?   @db.VarChar(120)
  items          Json
  subtotal       Float     @default(0)
  tax            Float     @default(0)
  total          Float     @default(0)
  due_date       DateTime?
  notes          String?   @db.Text
  estado_pago    String    @default("pendiente") @db.VarChar(20) // pendiente, pagado, cancelado
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("invoices")
}

